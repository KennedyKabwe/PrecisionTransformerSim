{
    "version": "0.2.0",
    "configurations": [
        {
            // ── Debug: Mode 1 (Ideal Transformer) ───────────────────────────
            // Press F5 to start debugging with these arguments
            "name": "Debug: Mode 1 (Ideal)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/transformer_sim.exe",
            "args": [
                "--mode", "1",
                "--V1", "230", "--f", "50",
                "--N1", "200", "--N2", "100",
                "--RL", "10"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,

            // GDB shipped with MSYS2 MinGW64 — adjust path if yours differs
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",

            "setupCommands": [
                {
                    "description": "Enable pretty-printing for STL types",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: Build"
        },
        {
            // ── Debug: Mode 2 (Core Losses) ──────────────────────────────────
            "name": "Debug: Mode 2 (Core Losses)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/transformer_sim.exe",
            "args": [
                "--mode", "2",
                "--V1", "230", "--f", "50",
                "--N1", "200", "--N2", "100",
                "--RL", "10",
                "--Rc", "500", "--Xm", "200"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for STL types",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: Build"
        },
        {
            // ── Debug: Mode 4 (Practical — full model) ────────────
            "name": "Debug: Mode 4 (Practical)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/transformer_sim.exe",
            "args": [
                "--mode", "4",
                "--V1", "230", "--f", "50",
                "--N1", "200", "--N2", "100",
                "--RL", "10",
                "--Rc", "500", "--Xm", "200",
                "--R1", "0.5", "--R2", "0.3",
                "--X1", "1.2", "--X2", "0.8"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/msys64/mingw64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for STL types",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "CMake: Build"
        }
    ]
}
