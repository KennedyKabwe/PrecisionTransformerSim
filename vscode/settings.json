{
    // ── C++ IntelliSense ──────────────────────────────────────────────────────
    // Points IntelliSense at our include/ folder so it understands all headers
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/src",
        "C:/msys64/mingw64/include",
        "C:/msys64/mingw64/include/c++/15.2.0"
    ],
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.compilerPath": "C:/msys64/mingw64/bin/g++.exe",
    "C_Cpp.default.intelliSenseMode": "windows-gcc-x64",

    // ── Editor ────────────────────────────────────────────────────────────────
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.detectIndentation": false,
    "editor.rulers": [100],          // visual guide at 100 characters

    // ── CMake ─────────────────────────────────────────────────────────────────
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.generator": "MinGW Makefiles",

    // ── File associations ─────────────────────────────────────────────────────
    "files.associations": {
        "*.h":   "cpp",
        "*.cpp": "cpp"
    },

    // ── Exclude build output from file explorer ───────────────────────────────
    "files.exclude": {
        "build/": true
    }
}
